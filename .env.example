# Derived from lana-bank docker-compose.yml service: core-pg
# core-pg exposes host port 5433 -> container 5432
# POSTGRES_USER=user POSTGRES_PASSWORD=password POSTGRES_DB=pg
PGHOST=127.0.0.1
PGPORT=5433
PGDATABASE=pg
PGUSER=user
PGPASSWORD=password
PGSSLMODE=disable

# Optional schema search path (comma-separated)
PGOPTIONS=

# Optional filters for timeline query
# Leave both empty => iterate ALL customers + facilities
# Set CUSTOMER_ID only => all facilities for that customer
# Set FACILITY_ID only => that facility (and its customer)
# Set both => exact customer/facility scope
CUSTOMER_ID=
FACILITY_ID=

# psql output format: aligned|csv|unaligned
OUTPUT_FORMAT=aligned
