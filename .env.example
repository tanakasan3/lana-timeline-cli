# Copy to .env and fill in values
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=lana
PGUSER=postgres
PGPASSWORD=postgres
PGSSLMODE=disable

# Optional schema search path (comma-separated)
PGOPTIONS=

# Default inputs for timeline query
CUSTOMER_ID=
FACILITY_ID=

# psql output format: aligned|csv|unaligned
OUTPUT_FORMAT=aligned
